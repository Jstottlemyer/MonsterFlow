# MonsterFlow ghostty theme — Apple Terminal "Homebrew" profile replica
# Classic green phosphor on black; cyan accents match config/tmux.conf so
# active-window/pane borders render in the same palette as tmux status.

background = #000000
foreground = #28fe14

cursor-color = #28fe14
cursor-text = #000000
cursor-style = block
cursor-style-blink = true

selection-background = #28fe14
selection-foreground = #000000

# ANSI palette — keep Ghostty defaults for colors 0-15 so syntax highlighting,
# ls colors, and tmux status (cyan for active window/pane borders) render correctly.

# Font — SF Mono is the Terminal.app Homebrew default on modern macOS
font-family = "SF Mono"
font-size = 13

# Window / layout
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true
background-opacity = 1.0

# macOS niceties
macos-option-as-alt = true
mouse-hide-while-typing = true
copy-on-select = false
